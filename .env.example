# Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required for inventory autocomplete lookup)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# n8n webhook base URL for inbound/outbound inventory operations (no trailing slash)
N8N_INVENTORY_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# Optional dedicated webhook URLs (use these when n8n gives full per-operation webhook paths)
N8N_INBOUND_WEBHOOK_URL=http://localhost:5678/webhook/inventory-inbound
N8N_OUTBOUND_WEBHOOK_URL=http://localhost:5678/webhook/inventory-outbound

# Dedicated n8n webhook URL for health-check requests
N8N_HEALTHCHECK_WEBHOOK_URL=http://localhost:5678/webhook/health-check
