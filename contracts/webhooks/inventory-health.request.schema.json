{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://globallogistics.local/schemas/inventory-health.request.schema.json",
  "title": "InventoryHealthCheckRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "timestamp",
    "includeDetails",
    "meta"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "includeDetails": {
      "type": "boolean",
      "description": "Whether the workflow should return the full low-stock item details."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "correlationId"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
